# ============================================================
# Taptico Discovery Platform -- Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git. It is already in .gitignore.
# ============================================================

# ------------------------------------------------------------
# ANTHROPIC (AI)
# The API key that powers the Bo interview agent.
# Get yours at: https://console.anthropic.com/settings/api-keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ------------------------------------------------------------
# SUPABASE (Database)
# These come from your Supabase project settings.
# Go to: Project Settings > API
#
# NEXT_PUBLIC_ prefix means this value is visible in the browser.
# The anon key is safe to expose -- it has very limited permissions.
# The service role key is SECRET -- never expose it to the browser.
# ------------------------------------------------------------

# Your project's URL (looks like: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your project's anon/public key (safe for browser use)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# Your project's service role key (SECRET -- server-side only, never expose)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here
